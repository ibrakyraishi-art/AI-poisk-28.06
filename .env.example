# Backend environment variables — copy to .env and fill in your values
# cp .env.example .env

# === Supabase (project: competitor-scope) ===
SUPABASE_URL=https://nqpeidlfkcxucgqykyrv.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here   # Dashboard → Settings → API → service_role
SUPABASE_JWT_SECRET=your_jwt_secret_here          # Dashboard → Settings → API → JWT Secret

# === LLM providers (at least one required) ===
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# === Web search ===
SERPER_API_KEY=...    # google.serper.dev — Business Context + Competitor Finder agents
NEWS_API_KEY=...      # newsapi.org — News Agent (optional, mock fallback if missing)

# === CORS (comma-separated frontend origins) ===
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
